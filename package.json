{
  "name": "@anmho/symphony",
  "version": "0.1.5",
  "description": "Local TypeScript Symphony runner for Linear-driven Codex app-server work orchestration.",
  "type": "module",
  "license": "UNLICENSED",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anmho/symphony.git"
  },
  "homepage": "https://www.npmjs.com/package/@anmho/symphony",
  "bugs": {
    "url": "https://github.com/anmho/symphony/issues"
  },
  "keywords": [
    "codex",
    "linear",
    "symphony",
    "worktrees"
  ],
  "files": [
    "dist",
    "templates",
    "README.md",
    "WORKFLOW.example.md"
  ],
  "bin": {
    "symphony": "dist/src/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts run",
    "install:global": "bun install && bun run build && bun link",
    "run": "tsx src/index.ts run",
    "start": "tsx src/index.ts start",
    "stop": "tsx src/index.ts stop",
    "status": "tsx src/index.ts status",
    "resume": "tsx src/index.ts resume",
    "watch": "tsx src/index.ts watch",
    "validate-config": "tsx src/index.ts validate-config",
    "templates:sync-linear": "tsx scripts/sync-linear-templates.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@opentui/core": "0.2.15",
    "commander": "^14.0.2",
    "liquidjs": "^10.27.0",
    "pino": "^10.1.0",
    "yaml": "^2.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=22"
  }
}
